# Copy this file to .env and fill in real values. .env is git-ignored.

# Required for LLM-backed components (classifier explanation, response drafting).
# Not required for deterministic components (readiness, missing-info, priority) or for
# unit tests, which mock the LLMClient interface instead of calling OpenAI directly.
OPENAI_API_KEY=

# Optional: override the default model used for classification/drafting.
OPENAI_MODEL=gpt-4o-mini
